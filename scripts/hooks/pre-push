#!/usr/bin/env bash
# pre-push hook — runs before every push
# Enforces: no push to main, full test suite passes
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo ""
echo "🚀 Running pre-push checks..."
echo ""

# ── 1. Block push to main ────────────────────────────────────────────────────
while read local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_ref" == "refs/heads/main" ]]; then
    echo -e "${RED}✗ Direct push to 'main' is not allowed.${NC}"
    echo "  Open a Pull Request instead."
    exit 1
  fi
done

# ── 2. Run full test suite for all packages ──────────────────────────────────
FAILED=0

for pkg in auth-client logging-lib event-lib testing-lib; do
  echo -e "${YELLOW}── Testing $pkg ──${NC}"
  if uv run --directory "$pkg" --extra dev pytest tests/ -v --tb=short -q 2>&1; then
    echo -e "  ${GREEN}✓ tests passed${NC}"
  else
    echo -e "  ${RED}✗ tests failed${NC}"
    FAILED=1
  fi
  echo ""
done

# ── 3. Secret scan (gitleaks if available) ───────────────────────────────────
if command -v gitleaks &>/dev/null; then
  echo -e "${YELLOW}── Secret scan ──${NC}"
  if gitleaks detect --source . --no-banner -q 2>&1; then
    echo -e "  ${GREEN}✓ no secrets detected${NC}"
  else
    echo -e "  ${RED}✗ gitleaks found potential secrets — review before pushing${NC}"
    FAILED=1
  fi
  echo ""
fi

if [ $FAILED -ne 0 ]; then
  echo -e "${RED}✗ Pre-push checks failed. Fix the issues above.${NC}"
  echo ""
  exit 1
fi

echo -e "${GREEN}✓ All pre-push checks passed. Pushing...${NC}"
echo ""
exit 0
